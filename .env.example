# Copy to `.env.local` for local dev, and set the same keys in
# Vercel → Settings → Environment Variables for Production + Preview.
# Only VITE_-prefixed vars are exposed to the client bundle.
#
# NOTE: everything here ships to the browser in plain text. This site has no
# backend and collects no PHI — never put a secret or API key in this file.

# Canonical origin used for canonical URLs, Open Graph, and JSON-LD.
# No trailing slash. Defaults to https://carentix.com when unset.
# On Vercel Preview, set this to the preview URL so canonicals aren't wrong.
VITE_SITE_URL=https://carentix.com

# --- Analytics (optional; leave blank to disable) ---------------------------
# Not yet wired into the app — documented here so the deploy config is ready.
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Plausible analytics domain, e.g. carentix.com
VITE_PLAUSIBLE_DOMAIN=
